@article{riihimaki_topological_2020,
 abstract = {Machine learning models for repeated measurements are limited. Using topological data analysis ({TDA}), we present a classifier for repeated measurements which samples from the data space and builds a network graph based on the data topology. A machine learning model with cross-validation is then applied for classification. When test this on three case studies, accuracy exceeds an alternative support vector machine ({SVM}) voting model in most situations tested, with additional benefits such as reporting data subsets with high purity along with feature values.},
 author = {Riihimäki, Henri and Chachólski, Wojciech and Theorell, Jakob and Hillert, Jan and Ramanujam, Ryan},
 date = {2020-07-29},
 doi = {10.1186/s12859-020-03659-3},
 issn = {1471-2105},
 journaltitle = {{BMC} Bioinformatics},
 keywords = {1 - Biology, 1 - Point process, 2 - Machine learning, 2 - Mapper, 2 - Point process, 3 - Tree species},
 langid = {english},
 number = {1},
 pages = {336},
 shortjournal = {{BMC} Bioinformatics},
 title = {A topological data analysis based classification method for multiple measurements},
 url = {https://doi.org/10.1186/s12859-020-03659-3},
 urldate = {2026-05-11},
 volume = {21}
}
